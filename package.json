{
  "name": "@nurseiit_sharip/jobber",
  "version": "1.0.2",
  "description": "Локальный персональный ассистент поиска работы по Telegram (provider-agnostic). CLI управления установкой, версиями и расписанием; интеллект — в Claude Code через MCP.",
  "bin": {
    "jobber": "bin/jobber.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepack": "find . -name __pycache__ -type d -prune -exec rm -rf {} + 2>/dev/null || true",
    "prepublishOnly": "node --check bin/jobber.js",
    "postinstall": "node bin/jobber.js _postinstall || true"
  },
  "files": [
    "bin/",
    "core/",
    "ingest/",
    "sources/",
    "matching/",
    "cover/",
    "digest/",
    "storage/",
    "mcp_server/",
    "registry.py",
    "pipeline.py",
    "config.yaml",
    ".env.example",
    "pyproject.toml",
    "profile/cv.md.template",
    ".claude/commands/",
    ".claude/agents/",
    "README.md",
    "CLAUDE.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "preferGlobal": true,
  "keywords": [
    "telegram",
    "job-search",
    "vacancies",
    "claude-code",
    "mcp",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nurs3it/jobber.git"
  },
  "bugs": {
    "url": "https://github.com/nurs3it/jobber/issues"
  },
  "homepage": "https://github.com/nurs3it/jobber#readme",
  "license": "MIT"
}
