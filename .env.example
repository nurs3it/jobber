# ============================================================
# Jobber — секреты (скопируйте в .env и заполните)
#   cp .env.example .env
# Файл .env в .gitignore. НИКОГДА не коммитить и не логировать.
# ============================================================

# --- Telegram API (получить на https://my.telegram.org → API development tools) ---
TG_API_ID=
TG_API_HASH=

# Телефон в международном формате, например +77001234567
TG_PHONE=

# Имя файла сессии Telethon (хранится локально, в .gitignore).
# Сам файл = полный доступ к аккаунту. Это секрет.
TG_SESSION_NAME=jobber

# --- LLM (опционально, если matching/cover вызываются программно вне Claude Code) ---
# В основном сценарии классификацию и письма делает Claude Code через MCP,
# и отдельный ключ не нужен. Заполните, только если запускаете конвейер автономно.
ANTHROPIC_API_KEY=
